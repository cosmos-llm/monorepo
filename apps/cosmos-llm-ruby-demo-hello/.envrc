#!/usr/bin/env bash

eval "$(devenv direnvrc)"

use devenv

# DLLM__ vars use PROVIDER__SETTING format (three double-underscore-separated parts).
# If the shell has the legacy single-separator form, map it across.
if [[ -n "${DLLM__ANTHROPIC_API_KEY:-}" && -z "${DLLM__ANTHROPIC__API_KEY:-}" ]]; then
  export DLLM__ANTHROPIC__API_KEY="${DLLM__ANTHROPIC_API_KEY}"
fi
