{
  "name": "cosmos-llm",
  "version": "0.1.0",
  "description": "A JavaScript/TypeScript library providing a unified interface for interacting with multiple Large Language Model APIs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "ai",
    "openai",
    "anthropic",
    "google",
    "gemini",
    "gpt",
    "claude",
    "mistral",
    "cohere",
    "machine-learning"
  ],
  "author": "Cosmos LLM Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cosmos-llm/cosmos-llm-js.git"
  },
  "homepage": "https://github.com/cosmos-llm/cosmos-llm-js",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.7.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
